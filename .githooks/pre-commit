#!/bin/sh
echo "Running pre-commit hooks (Prettier check)..."

# 1. Exempt if a merge commit is in progress
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  echo "Merge commit in progress. Exempting pre-commit hooks."
  exit 0
fi

# Get all staged files (exclude deletions: a removed file has no content for
# Prettier to check, and including it made the hook fail on normal removals).
ALL_STAGED=$(git diff --cached --name-only --diff-filter=d)

# If no files are staged, exit early
if [ -z "$ALL_STAGED" ]; then
  exit 0
fi

# Filter out documentation and image files to check if any code files are staged
CODE_STAGED=$(echo "$ALL_STAGED" | grep -v -E '\.(md|txt|png|jpg|jpeg|gif|svg)$')

if [ -z "$CODE_STAGED" ]; then
  echo "Only documentation, text, or asset changes detected. Exempting pre-commit hooks."
  exit 0
fi

# Find staged files matching frontend/src/ for Prettier check
STAGED_FILES=$(echo "$ALL_STAGED" | grep -E '^frontend/src/.*\.(ts|svelte|css)$')

if [ -z "$STAGED_FILES" ]; then
  echo "No staged frontend code files to check. Skipping Prettier check."
  exit 0
fi

echo "Checking formatting of staged files:"
for file in $STAGED_FILES; do
  echo "  - $file"
done

# Auto-format (autocorrect) the staged frontend files with Prettier, then
# re-stage them so the formatting fix rides along with the commit instead of
# blocking it. Prettier, prettier-plugin-svelte, and .prettierrc all live in
# frontend/ (the repo root has no package.json), so this MUST run from there —
# otherwise npx resolves a config-less prettier that can't parse Svelte syntax
# and fails on every .svelte file. Strip the leading "frontend/" from each
# path so they resolve from within frontend/.
FE_FILES=$(echo "$STAGED_FILES" | sed 's|^frontend/||')
if (cd frontend && npx prettier --write $FE_FILES); then
  # Re-stage any files Prettier reformatted so the commit includes the fix.
  git add $STAGED_FILES
else
  echo "ERROR: Prettier failed to format staged frontend files; see output above."
  exit 1
fi

echo "Pre-commit checks passed!"
exit 0
