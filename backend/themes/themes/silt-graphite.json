{
  "schema_version": "1.0.0",
  "id": "silt-graphite",
  "name": "Graphite",
  "author": "System Designer",
  "description": "A calm monochrome dark: cool near-black canvas with a single restrained blue accent.",
  "typography": {
    "font_family": "'Geist', sans-serif",
    "mono_font_family": "'Geist Mono', monospace",
    "headline_font": "'Schibsted Grotesk', sans-serif"
  },
  "modes": {
    "dark": {
      "bg": {
        "void": "#090a0c",
        "surface": "#0e1013",
        "panel": "#131619",
        "hover": "#191d21",
        "active": "#202429"
      },
      "border": {
        "muted": "#181b1f",
        "zinc": "#22262b",
        "active": "#363b42",
        "focus": "#5a6470"
      },
      "text": {
        "primary": "#e6e8eb",
        "muted": "#8b9097",
        "disabled": "#4a5057"
      },
      "accent": {
        "primary": {
          "start": "#7c93b8",
          "end": "#5a7196",
          "glow": "rgba(110,140,180,0.12)"
        },
        "secondary": {
          "start": "#9aa3ad",
          "end": "#6f7882",
          "glow": "rgba(140,150,160,0.10)"
        }
      },
      "status": {
        "warn": "#c9a368",
        "danger": "#b06868"
      }
    },
    "light": {
      "bg": {
        "void": "#f7f8f9",
        "surface": "#ffffff",
        "panel": "#f0f2f4",
        "hover": "#e6e9ec",
        "active": "#d2d7dc"
      },
      "border": {
        "muted": "#e6e9ec",
        "zinc": "#d2d7dc",
        "active": "#a7afb8",
        "focus": "#6b7480"
      },
      "text": {
        "primary": "#181b1f",
        "muted": "#4f5660",
        "disabled": "#9aa1a9"
      },
      "accent": {
        "primary": {
          "start": "#4a6184",
          "end": "#374d6e",
          "glow": "rgba(74,97,132,0.10)"
        },
        "secondary": {
          "start": "#6a737d",
          "end": "#525a63",
          "glow": "rgba(90,100,110,0.08)"
        }
      },
      "status": {
        "warn": "#9a6e1a",
        "danger": "#a33235"
      }
    }
  }
}
