{
  "schema_version": "1.0.0",
  "id": "silt-graphite",
  "name": "Graphite",
  "author": "System Designer",
  "description": "A calm monochrome dark: true neutral-gray canvas with a single restrained blue accent.",
  "typography": {
    "font_family": "'Geist', sans-serif",
    "mono_font_family": "'Geist Mono', monospace",
    "headline_font": "'Schibsted Grotesk', sans-serif"
  },
  "modes": {
    "dark": {
      "bg": {
        "void": "#0a0a0a",
        "surface": "#101010",
        "panel": "#161616",
        "hover": "#1d1d1d",
        "active": "#262626"
      },
      "border": {
        "muted": "#1b1b1b",
        "zinc": "#262626",
        "active": "#3a3a3a",
        "focus": "#5c5c5c"
      },
      "text": {
        "primary": "#ebebeb",
        "muted": "#9a9a9a",
        "disabled": "#4d4d4d"
      },
      "accent": {
        "primary": {
          "start": "#6f9ad8",
          "end": "#4d72a0",
          "glow": "rgba(111, 154, 216, 0.12)"
        },
        "secondary": {
          "start": "#9aa3ad",
          "end": "#6f7882",
          "glow": "rgba(140, 150, 160, 0.10)"
        }
      },
      "status": {
        "warn": "#c9a368",
        "danger": "#b06868"
      }
    },
    "light": {
      "bg": {
        "void": "#f8f8f8",
        "surface": "#ffffff",
        "panel": "#f0f0f0",
        "hover": "#e6e6e6",
        "active": "#d8d8d8"
      },
      "border": {
        "muted": "#e6e6e6",
        "zinc": "#d8d8d8",
        "active": "#bababa",
        "focus": "#6e6e6e"
      },
      "text": {
        "primary": "#1a1a1a",
        "muted": "#585858",
        "disabled": "#a3a3a3"
      },
      "accent": {
        "primary": {
          "start": "#4a6fa0",
          "end": "#374f78",
          "glow": "rgba(74, 111, 160, 0.10)"
        },
        "secondary": {
          "start": "#6a737d",
          "end": "#525a63",
          "glow": "rgba(90, 100, 110, 0.08)"
        }
      },
      "status": {
        "warn": "#9a6e1a",
        "danger": "#a33235"
      }
    }
  }
}
